# ── LLM (required) ──
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=4096

# ── Brave Search (recommended for broad queries) ──
BRAVE_API_KEY=your_brave_api_key_here

# ── Stash (optional — local or remote instance) ──
STASH_API_URL=
STASH_API_KEY=

# ── ThePornDB (optional — metadata enrichment) ──
THEPORNDB_API_URL=https://theporndb.net/graphql
THEPORNDB_API_KEY=

# ── Database ──
ENABLE_VECTOR_DB=false

# ── Server ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3333
RATE_LIMIT_RPM=30
LOG_LEVEL=INFO

# ── Scraper ──
SCRAPER_TIMEOUT=15
MAX_RESULTS_PER_SCRAPER=20
